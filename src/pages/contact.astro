---
import Base from '../layouts/Base.astro';
import site from '../content/site.json';
---

<Base title="联系我们" activeNav="contact">
  <section class="page-header">
    <div class="container">
      <h1>联系我们</h1>
      <p>一个微信、一个电话，开启一个项目的合作</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-4" style="margin-bottom: 48px;">
        <div class="contact-card">
          <div class="contact-icon" style="background: #dbeafe; color: #2563eb;">📍</div>
          <h3>公司地址</h3>
          <p>{site.address_full}</p>
        </div>
        <div class="contact-card">
          <div class="contact-icon" style="background: #dcfce7; color: #16a34a;">📞</div>
          <h3>联系电话</h3>
          <p>网站建设: {site.phone_mobile}</p>
          <p>网站优化: {site.phone_400}</p>
        </div>
        <div class="contact-card">
          <div class="contact-icon" style="background: #fef3c7; color: #d97706;">💬</div>
          <h3>微信联系</h3>
          <p>微信号: {site.wechat}</p>
          <p>扫码添加好友</p>
        </div>
        <div class="contact-card">
          <div class="contact-icon" style="background: #fce7f3; color: #db2777;">📧</div>
          <h3>电子邮箱</h3>
          <p><a href={`mailto:${site.email}`}>{site.email}</a></p>
        </div>
      </div>

      <div style="background: var(--bg-alt); border-radius: var(--radius); padding: 40px; text-align: center;">
        <h2 style="font-size: 1.5rem; margin-bottom: 12px;">工作时间</h2>
        <p style="color: var(--text-light); font-size: 1.1rem;">周一至周五 08:00 - 18:00</p>
        <p style="color: var(--text-muted); margin-top: 8px;">州内免费上门服务</p>
      </div>
    </div>
  </section>
</Base>
