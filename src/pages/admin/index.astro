---
// Admin SPA shell - no Astro layout needed
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>管理后台 | 滇码科技</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: { DEFAULT: '#2563eb', dark: '#1d4ed8', light: '#dbeafe' },
            },
            fontFamily: {
              sans: ['Noto Sans SC', '-apple-system', 'BlinkMacSystemFont', 'sans-serif'],
            },
          },
        },
      }
    </script>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif; }
    </style>
  </head>
  <body class="bg-slate-50 min-h-screen">
    <div id="admin-app"></div>
    <script is:inline src="/admin-config.js"></script>
    <script is:inline>
      // ============ CONFIG ============
      const GITHUB_API = 'https://api.github.com';
      const ADMIN_USERNAME = 'sw';
      const ADMIN_PASSWORD_HASH = '43d848684b2bdb7a7bef14950f10b71b53a78d067ffbf57873afc13d04ecbbfb';
      const GITHUB_TOKEN = (typeof __ADMIN_CONFIG__ !== 'undefined') ? __ADMIN_CONFIG__.GITHUB_TOKEN : '';
      const REPO_OWNER = (typeof __ADMIN_CONFIG__ !== 'undefined') ? __ADMIN_CONFIG__.REPO_OWNER : 'suwei8';
      const REPO_NAME = (typeof __ADMIN_CONFIG__ !== 'undefined') ? __ADMIN_CONFIG__.REPO_NAME : '13982.com';

      let token = '';
      let owner = REPO_OWNER;
      let repo = REPO_NAME;

      // ============ AUTH ============
      async function sha256(str) {
        const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
        return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
      }

      function isLoggedIn() {
        return sessionStorage.getItem('admin_logged_in') === 'true';
      }

      function doLogout() {
        sessionStorage.removeItem('admin_logged_in');
        token = '';
        renderApp();
      }

      async function doLogin() {
        const username = document.getElementById('inp-username').value.trim();
        const password = document.getElementById('inp-password').value;
        const msg = document.getElementById('login-msg');

        if (!username || !password) {
          msg.textContent = '请填写用户名和密码';
          msg.className = 'text-red-500 text-sm mt-3';
          return;
        }

        const hash = await sha256(password);
        if (username === ADMIN_USERNAME && hash === ADMIN_PASSWORD_HASH) {
          sessionStorage.setItem('admin_logged_in', 'true');
          token = GITHUB_TOKEN;
          renderApp();
        } else {
          msg.textContent = '用户名或密码错误';
          msg.className = 'text-red-500 text-sm mt-3';
        }
      }

      // ============ GITHUB API ============
      function headers() {
        return {
          'Authorization': `Bearer ${token}`,
          'Accept': 'application/vnd.github.v3+json',
          'Content-Type': 'application/json',
        };
      }

      function encodeBase64(str) {
        return btoa(unescape(encodeURIComponent(str)));
      }

      function decodeBase64(str) {
        return decodeURIComponent(escape(atob(str)));
      }

      async function api(method, path, body) {
        const opts = { method, headers: headers() };
        if (body) opts.body = JSON.stringify(body);
        const res = await fetch(`${GITHUB_API}${path}`, opts);
        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err.message || `GitHub API error: ${res.status}`);
        }
        return res.status === 204 ? null : res.json();
      }

      async function listFiles(dirPath) {
        try {
          return await api('GET', `/repos/${owner}/${repo}/contents/${dirPath}`);
        } catch (e) {
          if (e.message.includes('Not Found')) return [];
          throw e;
        }
      }

      async function getFile(filePath) {
        const data = await api('GET', `/repos/${owner}/${repo}/contents/${filePath}`);
        return { sha: data.sha, content: decodeBase64(data.content) };
      }

      async function saveFile(filePath, content, sha) {
        const body = { message: `admin: update ${filePath}`, content: encodeBase64(content) };
        if (sha) body.sha = sha;
        return api('PUT', `/repos/${owner}/${repo}/contents/${filePath}`, body);
      }

      async function deleteFile(filePath, sha) {
        return api('DELETE', `/repos/${owner}/${repo}/contents/${filePath}`, {
          message: `admin: delete ${filePath}`, sha,
        });
      }

      async function uploadImage(file) {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = async () => {
            const base64 = reader.result.split(',')[1];
            const ext = file.name.split('.').pop();
            const timestamp = Date.now();
            const path = `public/images/uploads/${timestamp}.${ext}`;
            try {
              const result = await api('PUT', `/repos/${owner}/${repo}/contents/${path}`, {
                message: `admin: upload image ${file.name}`,
                content: base64,
              });
              resolve({ path, url: `/images/uploads/${timestamp}.${ext}`, name: file.name });
            } catch (e) {
              reject(e);
            }
          };
          reader.readAsDataURL(file);
        });
      }

      // ============ FRONTMATTER ============
      function parseFrontmatter(md) {
        const match = md.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
        if (!match) return { data: {}, content: md };
        const data = {};
        match[1].split('\n').forEach(line => {
          const idx = line.indexOf(':');
          if (idx === -1) return;
          const key = line.slice(0, idx).trim();
          let val = line.slice(idx + 1).trim();
          if (val.startsWith('"') && val.endsWith('"')) val = val.slice(1, -1);
          if (val.startsWith('[') && val.endsWith(']')) {
            val = val.slice(1, -1).split(',').map(s => s.trim().replace(/"/g, ''));
          }
          data[key] = val;
        });
        return { data, content: match[2] };
      }

      function buildFrontmatter(data, content) {
        let fm = '---\n';
        for (const [key, val] of Object.entries(data)) {
          if (Array.isArray(val)) {
            fm += `${key}: [${val.map(v => `"${v}"`).join(', ')}]\n`;
          } else if (typeof val === 'string') {
            fm += `${key}: "${val}"\n`;
          } else {
            fm += `${key}: ${val}\n`;
          }
        }
        fm += '---\n\n';
        return fm + content;
      }

      // ============ RENDER ============
      function renderApp() {
        const app = document.getElementById('admin-app');
        if (!isLoggedIn()) {
          renderLogin(app);
        } else {
          token = GITHUB_TOKEN;
          renderDashboard(app);
        }
      }

      function renderLogin(app) {
        app.innerHTML = `
          <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-blue-50 via-sky-50 to-blue-100 px-4">
            <div class="w-full max-w-sm">
              <div class="text-center mb-8">
                <div class="inline-flex items-center gap-2 mb-3">
                  <span class="w-3 h-3 bg-primary rounded-full"></span>
                  <span class="text-xl font-bold text-slate-900">滇码科技</span>
                </div>
                <p class="text-sm text-slate-500">管理后台</p>
              </div>
              <div class="bg-white rounded-2xl shadow-lg p-8">
                <h2 class="text-lg font-semibold text-center mb-6">管理员登录</h2>
                <div class="mb-4">
                  <label class="block text-sm text-slate-600 mb-1.5">用户名</label>
                  <input id="inp-username" type="text" placeholder="请输入用户名"
                    class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
                </div>
                <div class="mb-6">
                  <label class="block text-sm text-slate-600 mb-1.5">密码</label>
                  <input id="inp-password" type="password" placeholder="请输入密码"
                    class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 transition-all" />
                </div>
                <button onclick="doLogin()"
                  class="w-full py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:bg-primary-dark transition-colors cursor-pointer">
                  登录
                </button>
                <p id="login-msg" class="text-sm mt-3 text-center"></p>
              </div>
            </div>
          </div>
        `;
        document.getElementById('inp-password').addEventListener('keydown', (e) => {
          if (e.key === 'Enter') doLogin();
        });
      }

      async function renderDashboard(app) {
        app.innerHTML = `
          <div class="flex min-h-screen">
            <!-- Sidebar -->
            <nav class="w-56 bg-slate-900 text-white flex flex-col shrink-0">
              <div class="p-5 border-b border-slate-800">
                <div class="flex items-center gap-2">
                  <span class="w-2 h-2 bg-primary rounded-full"></span>
                  <strong class="text-sm">滇码科技</strong>
                </div>
                <div class="text-xs text-slate-400 mt-1">管理后台</div>
              </div>
              <div class="flex-1 p-3 space-y-1">
                <a href="#" onclick="showSection('cases'); return false;" id="nav-cases"
                  class="block px-4 py-2 rounded-lg text-sm bg-primary text-white transition-colors">客户案例</a>
                <a href="#" onclick="showSection('services'); return false;" id="nav-services"
                  class="block px-4 py-2 rounded-lg text-sm text-slate-400 hover:text-white hover:bg-slate-800 transition-colors">产品服务</a>
              </div>
              <div class="p-4 border-t border-slate-800 space-y-2">
                <a href="/" target="_blank" class="block text-xs text-slate-400 hover:text-white transition-colors">查看网站</a>
                <a href="#" onclick="doLogout(); return false;" class="block text-xs text-red-400 hover:text-red-300 transition-colors">退出登录</a>
              </div>
            </nav>
            <!-- Main -->
            <main class="flex-1 p-8 overflow-auto" id="main-content">
              <p class="text-slate-400">加载中...</p>
            </main>
          </div>
        `;
        showSection('cases');
      }

      window.showSection = async function(section) {
        document.querySelectorAll('[id^="nav-"]').forEach(el => {
          el.className = el.className.replace(/bg-primary text-white/g, 'text-slate-400 hover:text-white hover:bg-slate-800');
        });
        const navEl = document.getElementById(`nav-${section}`);
        if (navEl) {
          navEl.className = navEl.className.replace(/text-slate-400 hover:text-white hover:bg-slate-800/g, 'bg-primary text-white');
        }
        if (section === 'cases') await renderCases();
        if (section === 'services') await renderServices();
      };

      // ============ CASES ============
      async function renderCases() {
        const main = document.getElementById('main-content');
        main.innerHTML = '<p class="text-slate-400">加载案例中...</p>';
        try {
          const files = await listFiles('src/content/cases');
          const cases = [];
          for (const f of files) {
            if (!f.name.endsWith('.md')) continue;
            const { sha, content } = await getFile(f.path);
            const { data } = parseFrontmatter(content);
            cases.push({ ...data, file: f.path, sha, filename: f.name });
          }
          main.innerHTML = `
            <div class="flex justify-between items-center mb-6">
              <h2 class="text-xl font-bold">客户案例 <span class="text-sm font-normal text-slate-400">(${cases.length})</span></h2>
              <button onclick="editCase()" class="px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-primary-dark transition-colors cursor-pointer">+ 新增案例</button>
            </div>
            <div class="space-y-3">
              ${cases.map(c => `
                <div class="bg-white p-4 rounded-xl border border-slate-200 flex justify-between items-center">
                  <div>
                    <strong class="text-sm">${c.title || '(无标题)'}</strong>
                    <div class="text-xs text-slate-400 mt-1">${c.description || ''}</div>
                  </div>
                  <div class="flex gap-2">
                    <button onclick="editCase('${c.file}')" class="px-3 py-1.5 border border-slate-200 rounded-lg text-xs cursor-pointer hover:bg-slate-50 transition-colors">编辑</button>
                    <button onclick="removeCase('${c.file}', '${c.sha}')" class="px-3 py-1.5 border border-red-200 rounded-lg text-xs text-red-500 cursor-pointer hover:bg-red-50 transition-colors">删除</button>
                  </div>
                </div>
              `).join('')}
            </div>
          `;
        } catch (e) {
          main.innerHTML = `<p class="text-red-500">加载失败: ${e.message}</p>`;
        }
      }

      window.editCase = async function(filePath) {
        const main = document.getElementById('main-content');
        let title = '', description = '', tags = '', thumbnail = '', content = '', sha = '';

        if (filePath) {
          try {
            const file = await getFile(filePath);
            sha = file.sha;
            const { data, content: body } = parseFrontmatter(file.content);
            title = data.title || '';
            description = data.description || '';
            tags = Array.isArray(data.tags) ? data.tags.join(', ') : (data.tags || '');
            thumbnail = data.thumbnail || '';
            content = body;
          } catch (e) {
            alert('加载失败: ' + e.message);
            return;
          }
        }

        main.innerHTML = `
          <h2 class="text-xl font-bold mb-6">${filePath ? '编辑案例' : '新增案例'}</h2>
          <div class="max-w-2xl space-y-4">
            <div>
              <label class="block text-sm text-slate-600 mb-1.5">标题</label>
              <input id="case-title" value="${title}" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
            </div>
            <div>
              <label class="block text-sm text-slate-600 mb-1.5">描述</label>
              <textarea id="case-desc" rows="3" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 resize-y">${description}</textarea>
            </div>
            <div>
              <label class="block text-sm text-slate-600 mb-1.5">标签 (逗号分隔)</label>
              <input id="case-tags" value="${tags}" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
            </div>
            <div>
              <label class="block text-sm text-slate-600 mb-1.5">缩略图</label>
              <div class="flex gap-2 items-center">
                <input id="case-thumbnail" value="${thumbnail}" placeholder="/images/cases/xxx.jpg" class="flex-1 px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
                <label class="px-4 py-2.5 bg-slate-100 border border-slate-200 rounded-xl text-sm cursor-pointer hover:bg-slate-200 transition-colors shrink-0">
                  上传图片
                  <input type="file" accept="image/*" class="hidden" onchange="handleThumbUpload(this)" />
                </label>
              </div>
              <div id="thumb-preview" class="mt-2">${thumbnail ? `<img src="${thumbnail}" class="w-32 h-20 object-cover rounded-lg border" />` : ''}</div>
            </div>
            <div>
              <label class="block text-sm text-slate-600 mb-1.5">正文内容 (Markdown)</label>
              <div class="border border-slate-200 rounded-xl overflow-hidden">
                <div class="bg-slate-50 px-4 py-2 border-b border-slate-200 flex gap-2">
                  <label class="px-3 py-1 bg-white border border-slate-200 rounded-lg text-xs cursor-pointer hover:bg-slate-50 transition-colors">
                    插入图片
                    <input type="file" accept="image/*" class="hidden" onchange="handleContentImageUpload(this)" />
                  </label>
                </div>
                <textarea id="case-content" rows="12" class="w-full px-4 py-3 border-none text-sm font-mono focus:outline-none resize-y">${content}</textarea>
              </div>
            </div>
            <div class="flex gap-3 pt-2">
              <button onclick="saveCase('${filePath}', '${sha}')" class="px-6 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:bg-primary-dark transition-colors cursor-pointer">保存</button>
              <button onclick="showSection('cases')" class="px-6 py-2.5 border border-slate-200 rounded-xl text-sm hover:bg-slate-50 transition-colors cursor-pointer">取消</button>
            </div>
            <p id="case-msg" class="text-sm"></p>
          </div>
        `;
      };

      window.handleThumbUpload = async function(input) {
        const file = input.files[0];
        if (!file) return;
        const preview = document.getElementById('thumb-preview');
        preview.innerHTML = '<p class="text-xs text-slate-400">上传中...</p>';
        try {
          const result = await uploadImage(file);
          document.getElementById('case-thumbnail').value = result.url;
          preview.innerHTML = `<img src="${result.url}" class="w-32 h-20 object-cover rounded-lg border" />`;
        } catch (e) {
          preview.innerHTML = `<p class="text-xs text-red-500">上传失败: ${e.message}</p>`;
        }
        input.value = '';
      };

      window.handleContentImageUpload = async function(input) {
        const file = input.files[0];
        if (!file) return;
        const textarea = document.getElementById('case-content');
        const cursorPos = textarea.selectionStart;
        const textBefore = textarea.value.substring(0, cursorPos);
        const textAfter = textarea.value.substring(cursorPos);
        textarea.value = textBefore + '![上传中...](上传中...)' + textAfter;
        try {
          const result = await uploadImage(file);
          textarea.value = textarea.value.replace('![上传中...](上传中...)', `![${result.name}](${result.url})`);
        } catch (e) {
          textarea.value = textarea.value.replace('![上传中...](上传中...)', `![上传失败]()`);
          alert('图片上传失败: ' + e.message);
        }
        input.value = '';
      };

      window.saveCase = async function(filePath, sha) {
        const msg = document.getElementById('case-msg');
        const title = document.getElementById('case-title').value.trim();
        const desc = document.getElementById('case-desc').value.trim();
        const tags = document.getElementById('case-tags').value.split(',').map(s => s.trim()).filter(Boolean);
        const thumbnail = document.getElementById('case-thumbnail').value.trim();
        const body = document.getElementById('case-content').value;

        if (!title) { msg.textContent = '请填写标题'; msg.className = 'text-red-500 text-sm mt-2'; return; }

        const slug = title.toLowerCase().replace(/[^a-z0-9一-鿿]+/g, '-').replace(/^-|-$/g, '');
        const safeSlug = slug || `case-${Date.now()}`;
        const newPath = filePath || `src/content/cases/${safeSlug}.md`;

        const md = buildFrontmatter({
          title, description: desc, thumbnail, tags,
          date: new Date().toISOString().split('T')[0],
        }, body);

        try {
          msg.textContent = '保存中...'; msg.className = 'text-slate-400 text-sm mt-2';
          await saveFile(newPath, md, sha || undefined);
          msg.textContent = '保存成功！EdgeOne Pages 将自动重新构建。'; msg.className = 'text-green-500 text-sm mt-2';
          setTimeout(() => showSection('cases'), 1500);
        } catch (e) {
          msg.textContent = '保存失败: ' + e.message; msg.className = 'text-red-500 text-sm mt-2';
        }
      };

      window.removeCase = async function(filePath, sha) {
        if (!confirm('确定删除这个案例吗？')) return;
        try {
          await deleteFile(filePath, sha);
          renderCases();
        } catch (e) {
          alert('删除失败: ' + e.message);
        }
      };

      // ============ SERVICES ============
      async function renderServices() {
        const main = document.getElementById('main-content');
        main.innerHTML = '<p class="text-slate-400">加载服务中...</p>';
        try {
          const files = await listFiles('src/content/services');
          const services = [];
          for (const f of files) {
            if (!f.name.endsWith('.md')) continue;
            const { sha, content } = await getFile(f.path);
            const { data } = parseFrontmatter(content);
            services.push({ ...data, file: f.path, sha, filename: f.name });
          }
          services.sort((a, b) => (a.order || 0) - (b.order || 0));
          main.innerHTML = `
            <div class="flex justify-between items-center mb-6">
              <h2 class="text-xl font-bold">产品服务 <span class="text-sm font-normal text-slate-400">(${services.length})</span></h2>
              <button onclick="editService()" class="px-4 py-2 bg-primary text-white rounded-lg text-sm hover:bg-primary-dark transition-colors cursor-pointer">+ 新增服务</button>
            </div>
            <div class="space-y-3">
              ${services.map(s => `
                <div class="bg-white p-4 rounded-xl border border-slate-200 flex justify-between items-center">
                  <div>
                    <strong class="text-sm">${s.title || '(无标题)'}</strong>
                    <div class="text-xs text-slate-400 mt-1">${s.description || ''}</div>
                  </div>
                  <div class="flex gap-2">
                    <button onclick="editService('${s.file}')" class="px-3 py-1.5 border border-slate-200 rounded-lg text-xs cursor-pointer hover:bg-slate-50 transition-colors">编辑</button>
                    <button onclick="removeService('${s.file}', '${s.sha}')" class="px-3 py-1.5 border border-red-200 rounded-lg text-xs text-red-500 cursor-pointer hover:bg-red-50 transition-colors">删除</button>
                  </div>
                </div>
              `).join('')}
            </div>
          `;
        } catch (e) {
          main.innerHTML = `<p class="text-red-500">加载失败: ${e.message}</p>`;
        }
      }

      window.editService = async function(filePath) {
        const main = document.getElementById('main-content');
        let title = '', description = '', order = '0', content = '', sha = '';

        if (filePath) {
          try {
            const file = await getFile(filePath);
            sha = file.sha;
            const { data, content: body } = parseFrontmatter(file.content);
            title = data.title || '';
            description = data.description || '';
            order = String(data.order || '0');
            content = body;
          } catch (e) {
            alert('加载失败: ' + e.message);
            return;
          }
        }

        main.innerHTML = `
          <h2 class="text-xl font-bold mb-6">${filePath ? '编辑服务' : '新增服务'}</h2>
          <div class="max-w-2xl space-y-4">
            <div>
              <label class="block text-sm text-slate-600 mb-1.5">标题</label>
              <input id="svc-title" value="${title}" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
            </div>
            <div>
              <label class="block text-sm text-slate-600 mb-1.5">描述</label>
              <textarea id="svc-desc" rows="3" class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 resize-y">${description}</textarea>
            </div>
            <div>
              <label class="block text-sm text-slate-600 mb-1.5">排序 (数字越小越靠前)</label>
              <input id="svc-order" type="number" value="${order}" class="w-32 px-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/20" />
            </div>
            <div>
              <label class="block text-sm text-slate-600 mb-1.5">正文内容 (Markdown)</label>
              <div class="border border-slate-200 rounded-xl overflow-hidden">
                <div class="bg-slate-50 px-4 py-2 border-b border-slate-200 flex gap-2">
                  <label class="px-3 py-1 bg-white border border-slate-200 rounded-lg text-xs cursor-pointer hover:bg-slate-50 transition-colors">
                    插入图片
                    <input type="file" accept="image/*" class="hidden" onchange="handleServiceImageUpload(this)" />
                  </label>
                </div>
                <textarea id="svc-content" rows="12" class="w-full px-4 py-3 border-none text-sm font-mono focus:outline-none resize-y">${content}</textarea>
              </div>
            </div>
            <div class="flex gap-3 pt-2">
              <button onclick="saveService('${filePath}', '${sha}')" class="px-6 py-2.5 bg-primary text-white rounded-xl text-sm font-medium hover:bg-primary-dark transition-colors cursor-pointer">保存</button>
              <button onclick="showSection('services')" class="px-6 py-2.5 border border-slate-200 rounded-xl text-sm hover:bg-slate-50 transition-colors cursor-pointer">取消</button>
            </div>
            <p id="svc-msg" class="text-sm"></p>
          </div>
        `;
      };

      window.handleServiceImageUpload = async function(input) {
        const file = input.files[0];
        if (!file) return;
        const textarea = document.getElementById('svc-content');
        const cursorPos = textarea.selectionStart;
        const textBefore = textarea.value.substring(0, cursorPos);
        const textAfter = textarea.value.substring(cursorPos);
        textarea.value = textBefore + '![上传中...](上传中...)' + textAfter;
        try {
          const result = await uploadImage(file);
          textarea.value = textarea.value.replace('![上传中...](上传中...)', `![${result.name}](${result.url})`);
        } catch (e) {
          textarea.value = textarea.value.replace('![上传中...](上传中...)', `![上传失败]()`);
          alert('图片上传失败: ' + e.message);
        }
        input.value = '';
      };

      window.saveService = async function(filePath, sha) {
        const msg = document.getElementById('svc-msg');
        const title = document.getElementById('svc-title').value.trim();
        const desc = document.getElementById('svc-desc').value.trim();
        const order = parseInt(document.getElementById('svc-order').value) || 99;
        const body = document.getElementById('svc-content').value;

        if (!title) { msg.textContent = '请填写标题'; msg.className = 'text-red-500 text-sm mt-2'; return; }

        const slug = title.toLowerCase().replace(/[^a-z0-9一-鿿]+/g, '-').replace(/^-|-$/g, '');
        const safeSlug = slug || `service-${Date.now()}`;
        const newPath = filePath || `src/content/services/${safeSlug}.md`;

        const md = buildFrontmatter({ title, description: desc, icon: '', order }, body);

        try {
          msg.textContent = '保存中...'; msg.className = 'text-slate-400 text-sm mt-2';
          await saveFile(newPath, md, sha || undefined);
          msg.textContent = '保存成功！'; msg.className = 'text-green-500 text-sm mt-2';
          setTimeout(() => showSection('services'), 1500);
        } catch (e) {
          msg.textContent = '保存失败: ' + e.message; msg.className = 'text-red-500 text-sm mt-2';
        }
      };

      window.removeService = async function(filePath, sha) {
        if (!confirm('确定删除这个服务吗？')) return;
        try {
          await deleteFile(filePath, sha);
          renderServices();
        } catch (e) {
          alert('删除失败: ' + e.message);
        }
      };

      // Boot
      renderApp();
    </script>
  </body>
</html>
