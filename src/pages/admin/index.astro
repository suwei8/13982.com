---
// Admin SPA — 账号密码登录 + 内容/上传/站点管理。
// 所有写操作通过同源 /api/* 走；Token 存 localStorage，永不出现在源码中。
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>管理后台 | 滇码科技</title>
    <style is:inline>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Microsoft YaHei', sans-serif;
        background: #f1f5f9; color: #0f172a;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      button { font-family: inherit; cursor: pointer; }
      input, textarea, select { font-family: inherit; }
      a { color: #2563eb; }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }

      /* Layout */
      .app { display: flex; min-height: 100vh; }
      .sidebar {
        width: 220px; background: #0f172a; color: #cbd5e1;
        display: flex; flex-direction: column;
        position: sticky; top: 0; height: 100vh;
      }
      .sidebar-brand { padding: 20px 18px; font-weight: 700; color: #f8fafc; font-size: 15px; letter-spacing: 0.5px; border-bottom: 1px solid #1e293b; }
      .sidebar-nav { flex: 1; padding: 12px 8px; }
      .nav-item {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 12px; border-radius: 8px; cursor: pointer;
        color: #cbd5e1; font-size: 14px; margin-bottom: 2px;
        border: none; background: transparent; width: 100%; text-align: left;
        transition: background 0.15s, color 0.15s;
      }
      .nav-item:hover { background: #1e293b; color: #f8fafc; }
      .nav-item.active { background: #2563eb; color: #fff; }
      .nav-icon { width: 18px; height: 18px; flex: 0 0 18px; opacity: 0.85; }
      .sidebar-foot { padding: 14px 18px; border-top: 1px solid #1e293b; font-size: 12px; color: #64748b; }

      .main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
      .topbar {
        height: 56px; background: #fff; border-bottom: 1px solid #e2e8f0;
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 24px; position: sticky; top: 0; z-index: 10;
      }
      .topbar-title { font-weight: 600; font-size: 15px; }
      .topbar-user { display: flex; align-items: center; gap: 12px; font-size: 13px; color: #475569; }
      .topbar-user button { border: 1px solid #cbd5e1; background: #fff; color: #334155; padding: 6px 12px; border-radius: 6px; font-size: 13px; }
      .topbar-user button:hover { background: #f8fafc; }

      .content { padding: 24px; flex: 1; }
      .panel { display: none; }
      .panel.active { display: block; }
      .panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; flex-wrap: wrap; gap: 10px; }
      .panel-title { font-size: 20px; font-weight: 700; }
      .panel-sub { color: #64748b; font-size: 13px; margin-top: 2px; }

      .btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 14px; border-radius: 8px; font-size: 13px; font-weight: 500;
        border: 1px solid transparent; transition: all 0.15s;
      }
      .btn-primary { background: #2563eb; color: #fff; }
      .btn-primary:hover:not(:disabled) { background: #1d4ed8; }
      .btn-primary:disabled { opacity: 0.55; cursor: not-allowed; }
      .btn-secondary { background: #fff; color: #334155; border-color: #cbd5e1; }
      .btn-secondary:hover:not(:disabled) { background: #f1f5f9; }
      .btn-danger { background: #fff; color: #dc2626; border-color: #fecaca; }
      .btn-danger:hover:not(:disabled) { background: #fef2f2; }
      .btn-ghost { background: transparent; color: #475569; }
      .btn-ghost:hover { background: #e2e8f0; }
      .btn-sm { padding: 5px 10px; font-size: 12px; }

      .card { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; }
      .table { width: 100%; border-collapse: collapse; }
      .table th, .table td { padding: 12px 16px; text-align: left; font-size: 13px; vertical-align: top; }
      .table th { background: #f8fafc; color: #475569; font-weight: 600; border-bottom: 1px solid #e2e8f0; font-size: 12px; text-transform: uppercase; letter-spacing: 0.3px; }
      .table tr + tr td { border-top: 1px solid #f1f5f9; }
      .table tr:hover td { background: #f8fafc; }
      .table-actions { display: flex; gap: 6px; justify-content: flex-end; }
      .empty { padding: 40px 20px; text-align: center; color: #94a3b8; font-size: 13px; }

      .tag { display: inline-block; padding: 2px 8px; background: #e0f2fe; color: #0369a1; border-radius: 4px; font-size: 11px; margin-right: 4px; margin-top: 2px; }

      /* Login */
      .login-wrap { min-height: 100vh; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, #1e3a8a, #0f172a); padding: 20px; }
      .login-card { background: #fff; border-radius: 16px; padding: 36px 32px; width: 100%; max-width: 380px; box-shadow: 0 20px 60px rgba(0,0,0,0.25); }
      .login-title { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
      .login-sub { color: #64748b; font-size: 13px; margin-bottom: 24px; }
      .form-group { margin-bottom: 14px; }
      .form-group label { display: block; font-size: 12px; color: #475569; margin-bottom: 6px; font-weight: 500; }
      .form-group label .req { color: #dc2626; }
      .form-input {
        width: 100%; padding: 10px 12px; border: 1px solid #cbd5e1; border-radius: 8px;
        font-size: 14px; background: #fff; color: #0f172a;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .form-input:focus { outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.15); }
      .form-input:disabled { background: #f1f5f9; }
      textarea.form-input { resize: vertical; min-height: 80px; font-family: ui-monospace, SFMono-Regular, Menlo, monospace; }
      .form-hint { font-size: 11px; color: #94a3b8; margin-top: 4px; }
      .login-err { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; border-radius: 8px; padding: 10px 12px; font-size: 13px; margin-bottom: 14px; display: none; }
      .login-err.show { display: block; }
      .login-foot { margin-top: 18px; font-size: 12px; color: #94a3b8; text-align: center; }

      /* Modal */
      .modal-bg {
        position: fixed; inset: 0; background: rgba(15, 23, 42, 0.55);
        display: none; align-items: center; justify-content: center; z-index: 50; padding: 20px;
      }
      .modal-bg.show { display: flex; }
      .modal { background: #fff; border-radius: 12px; width: 100%; max-width: 560px; max-height: 90vh; display: flex; flex-direction: column; }
      .modal-head { padding: 16px 20px; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; }
      .modal-title { font-size: 16px; font-weight: 600; }
      .modal-close { background: transparent; border: none; font-size: 20px; line-height: 1; color: #64748b; padding: 4px 8px; border-radius: 6px; }
      .modal-close:hover { background: #f1f5f9; color: #0f172a; }
      .modal-body { padding: 20px; overflow-y: auto; flex: 1; }
      .modal-foot { padding: 14px 20px; border-top: 1px solid #e2e8f0; display: flex; justify-content: flex-end; gap: 8px; background: #f8fafc; border-radius: 0 0 12px 12px; }

      /* Toast */
      .toast-wrap { position: fixed; top: 16px; left: 50%; transform: translateX(-50%); z-index: 100; display: flex; flex-direction: column; gap: 8px; pointer-events: none; }
      .toast {
        background: #0f172a; color: #f8fafc; padding: 10px 16px; border-radius: 8px;
        font-size: 13px; pointer-events: auto; min-width: 220px; max-width: 460px;
        display: flex; align-items: center; gap: 10px; box-shadow: 0 10px 30px rgba(0,0,0,0.25);
        animation: toast-in 0.2s ease-out;
      }
      .toast.success { background: #16a34a; }
      .toast.error { background: #dc2626; }
      .toast .toast-x { background: transparent; border: none; color: inherit; opacity: 0.7; padding: 0 4px; font-size: 16px; }
      .toast .toast-x:hover { opacity: 1; }
      @keyframes toast-in { from { opacity: 0; transform: translateY(-8px); } to { opacity: 1; transform: translateY(0); } }

      /* Upload */
      .upload-zone { border: 2px dashed #cbd5e1; border-radius: 12px; padding: 28px; text-align: center; background: #fff; transition: border-color 0.15s, background 0.15s; }
      .upload-zone.drag { border-color: #2563eb; background: #eff6ff; }
      .upload-list { margin-top: 16px; display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 12px; }
      .upload-item { background: #fff; border: 1px solid #e2e8f0; border-radius: 8px; padding: 10px; }
      .upload-item .url-row { display: flex; gap: 6px; align-items: center; }
      .upload-item input { flex: 1; font-size: 11px; padding: 5px 8px; border: 1px solid #e2e8f0; border-radius: 4px; background: #f8fafc; }

      .helper { font-size: 12px; color: #64748b; margin-top: 8px; }
      .err-text { color: #b91c1c; font-size: 12px; margin-top: 4px; }

      @media (max-width: 720px) {
        .sidebar { width: 64px; }
        .sidebar-brand { font-size: 12px; padding: 18px 8px; text-align: center; }
        .nav-item span:not(.nav-icon) { display: none; }
        .topbar { padding: 0 14px; }
        .content { padding: 14px; }
        .table th, .table td { padding: 10px 8px; }
        .table .col-hide-sm { display: none; }
      }
    </style>
  </head>
  <body>
    <div id="root"></div>
    <div class="toast-wrap" id="toasts"></div>
    <div class="modal-bg" id="modalBg">
      <div class="modal">
        <div class="modal-head">
          <div class="modal-title" id="modalTitle">标题</div>
          <button class="modal-close" id="modalClose" aria-label="关闭">×</button>
        </div>
        <div class="modal-body" id="modalBody"></div>
        <div class="modal-foot" id="modalFoot"></div>
      </div>
    </div>

    <script type="module">
      // ===== 状态 =====
      const TOKEN_KEY = 'dm_admin_token';
      const USER_KEY = 'dm_admin_user';
      const state = {
        token: localStorage.getItem(TOKEN_KEY) || null,
        user: localStorage.getItem(USER_KEY) || null,
        activeTab: 'cases',
        cases: [],
        services: [],
        site: { sha: null, raw: '' },
        uploads: [],
      };

      // ===== 工具 =====
      const $ = (sel, root = document) => root.querySelector(sel);
      const el = (tag, attrs = {}, ...children) => {
        const node = document.createElement(tag);
        for (const [k, v] of Object.entries(attrs)) {
          if (k === 'class') node.className = v;
          else if (k === 'style' && typeof v === 'object') Object.assign(node.style, v);
          else if (k.startsWith('on') && typeof v === 'function') node.addEventListener(k.slice(2), v);
          else if (k === 'html') node.innerHTML = v;
          else if (v === true) node.setAttribute(k, '');
          else if (v !== false && v != null) node.setAttribute(k, v);
        }
        for (const c of children.flat()) {
          if (c == null || c === false) continue;
          node.append(c.nodeType ? c : document.createTextNode(String(c)));
        }
        return node;
      };

      const fmtDate = (v) => {
        if (!v) return '';
        if (v instanceof Date) return v.toISOString().slice(0, 10);
        // 服务端可能返回 ISO 字符串
        if (typeof v === 'string') return v.slice(0, 10);
        return String(v);
      };

      function toast(msg, type = 'info') {
        const wrap = $('#toasts');
        const node = el('div', { class: `toast ${type}` },
          el('span', { style: { flex: 1 } }, msg),
          el('button', { class: 'toast-x', onclick: () => node.remove() }, '×')
        );
        wrap.appendChild(node);
        setTimeout(() => node.remove(), 3000);
      }

      function showModal({ title, body, foot, onClose }) {
        $('#modalTitle').textContent = title;
        const bodyEl = $('#modalBody');
        bodyEl.innerHTML = '';
        if (typeof body === 'string') bodyEl.innerHTML = body;
        else if (body) bodyEl.appendChild(body);
        const footEl = $('#modalFoot');
        footEl.innerHTML = '';
        if (typeof foot === 'string') footEl.innerHTML = foot;
        else if (foot) footEl.appendChild(foot);
        $('#modalBg').classList.add('show');
        const close = () => { $('#modalBg').classList.remove('show'); onClose && onClose(); };
        $('#modalClose').onclick = close;
        const onKey = (e) => { if (e.key === 'Escape') { close(); document.removeEventListener('keydown', onKey); } };
        document.addEventListener('keydown', onKey);
        return close;
      }

      // ===== API =====
      async function api(path, opts = {}) {
        const headers = { ...(opts.headers || {}) };
        if (state.token) headers['Authorization'] = `Bearer ${state.token}`;
        const res = await fetch(path, { ...opts, headers });
        if (res.status === 401) {
          logout('会话已过期，请重新登录');
          throw new Error('未授权');
        }
        const ct = res.headers.get('content-type') || '';
        if (!res.ok) {
          let msg = `请求失败 (${res.status})`;
          try {
            const j = ct.includes('json') ? await res.json() : await res.text();
            msg = (j && j.error) || msg;
          } catch {}
          throw new Error(msg);
        }
        if (res.status === 204) return null;
        return ct.includes('json') ? res.json() : res.text();
      }

      const apiLogin = (username, password) =>
        fetch('/api/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username, password }),
        }).then(async (res) => {
          const data = await res.json().catch(() => ({}));
          if (!res.ok) throw new Error(data.error || `登录失败 (${res.status})`);
          return data;
        });

      const apiContent = {
        list: (type) => api(`/api/content?type=${type}`),
        get: (path) => api(`/api/content/item?path=${encodeURIComponent(path)}`),
        save: (payload) => api('/api/content', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) }),
        remove: (path, sha) => api(`/api/content?path=${encodeURIComponent(path)}&sha=${encodeURIComponent(sha)}`, { method: 'DELETE' }),
      };

      const apiSite = {
        load: () => api('/api/site'),
        save: (data, sha) => api('/api/site', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ data, sha }) }),
      };

      const apiUpload = (file) => {
        const fd = new FormData();
        fd.append('file', file);
        return api('/api/upload', { method: 'POST', body: fd });
      };

      // ===== 鉴权 =====
      function setSession(token, user) {
        state.token = token;
        state.user = user;
        localStorage.setItem(TOKEN_KEY, token);
        localStorage.setItem(USER_KEY, user);
      }

      function logout(reason) {
        state.token = null;
        state.user = null;
        localStorage.removeItem(TOKEN_KEY);
        localStorage.removeItem(USER_KEY);
        if (reason) toast(reason, 'error');
        render();
      }

      async function doLogin(username, password) {
        const data = await apiLogin(username, password);
        setSession(data.token, username);
        toast('登录成功', 'success');
        render();
      }

      // ===== 视图 =====
      function renderLogin() {
        const root = $('#root');
        root.innerHTML = '';
        const card = el('div', { class: 'login-card' });
        const errBox = el('div', { class: 'login-err', id: 'loginErr' });
        const userInput = el('input', { class: 'form-input', type: 'text', id: 'loginUser', autocomplete: 'username', placeholder: '管理员账号' });
        const passInput = el('input', { class: 'form-input', type: 'password', id: 'loginPass', autocomplete: 'current-password', placeholder: '密码' });
        const submit = el('button', { class: 'btn btn-primary', style: { width: '100%', justifyContent: 'center', marginTop: '6px' } }, '登录');

        const onSubmit = async () => {
          const u = userInput.value.trim();
          const p = passInput.value;
          if (!u || !p) { errBox.textContent = '请输入账号和密码'; errBox.classList.add('show'); return; }
          errBox.classList.remove('show');
          submit.disabled = true; submit.textContent = '登录中...';
          try { await doLogin(u, p); }
          catch (e) { errBox.textContent = e.message; errBox.classList.add('show'); }
          finally { submit.disabled = false; submit.textContent = '登录'; }
        };
        submit.addEventListener('click', onSubmit);
        [userInput, passInput].forEach((inp) => inp.addEventListener('keydown', (e) => { if (e.key === 'Enter') onSubmit(); }));

        card.append(
          el('div', { class: 'login-title' }, '滇码科技 · 管理后台'),
          el('div', { class: 'login-sub' }, '使用账号密码登录'),
          errBox,
          el('div', { class: 'form-group' }, el('label', {}, '账号'), userInput),
          el('div', { class: 'form-group' }, el('label', {}, '密码'), passInput),
          submit,
          el('div', { class: 'login-foot' }, '会话有效期 12 小时，关闭浏览器后需重新登录')
        );
        const wrap = el('div', { class: 'login-wrap' }, card);
        root.appendChild(wrap);
        setTimeout(() => userInput.focus(), 30);
      }

      function renderShell() {
        const root = $('#root');
        root.innerHTML = '';

        const navItem = (key, label, icon) => {
          const btn = el('button', { class: `nav-item ${state.activeTab === key ? 'active' : ''}` },
            el('span', { class: 'nav-icon', html: icon }),
            el('span', {}, label)
          );
          btn.addEventListener('click', () => { state.activeTab = key; renderShell(); });
          return btn;
        };

        const sidebar = el('aside', { class: 'sidebar' },
          el('div', { class: 'sidebar-brand' }, '滇码管理后台'),
          el('nav', { class: 'sidebar-nav' },
            navItem('cases', '案例', '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7h18M3 12h18M3 17h18"/></svg>'),
            navItem('services', '服务', '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33h.01a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h.01a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.01a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>'),
            navItem('site', '站点信息', '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 0 20M12 2a15.3 15.3 0 0 0 0 20"/></svg>'),
            navItem('upload', '图片上传', '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>'),
          ),
          el('div', { class: 'sidebar-foot' }, '© 滇码科技')
        );

        const titles = { cases: '客户案例', services: '产品服务', site: '站点信息', upload: '图片上传' };
        const logoutBtn = el('button', { onclick: () => logout() }, '退出登录');
        const topbar = el('div', { class: 'topbar' },
          el('div', { class: 'topbar-title' }, titles[state.activeTab] || ''),
          el('div', { class: 'topbar-user' },
            el('span', {}, `👤 ${state.user || ''}`),
            logoutBtn
          )
        );

        const content = el('main', { class: 'content' });
        if (state.activeTab === 'cases') content.appendChild(renderCasesPanel());
        else if (state.activeTab === 'services') content.appendChild(renderServicesPanel());
        else if (state.activeTab === 'site') content.appendChild(renderSitePanel());
        else if (state.activeTab === 'upload') content.appendChild(renderUploadPanel());

        const main = el('section', { class: 'main' }, topbar, content);
        const app = el('div', { class: 'app' }, sidebar, main);
        root.appendChild(app);
      }

      // ===== 案例面板 =====
      function renderCasesPanel() {
        const wrap = el('div');
        const refreshBtn = el('button', { class: 'btn btn-secondary btn-sm', onclick: loadCases }, '↻ 刷新');
        const newBtn = el('button', { class: 'btn btn-primary btn-sm', onclick: () => openCaseForm() }, '+ 新增案例');

        const head = el('div', { class: 'panel-header' },
          el('div', {},
            el('div', { class: 'panel-title' }, '客户案例'),
            el('div', { class: 'panel-sub' }, `共 ${state.cases.length} 条 · 编辑保存后 EdgeOne 会在 30-60 秒内自动重新部署`)
          ),
          el('div', { style: { display: 'flex', gap: '8px' } }, refreshBtn, newBtn)
        );

        const tableWrap = el('div', { class: 'card' });
        const renderTable = () => {
          tableWrap.innerHTML = '';
          if (state.cases.length === 0) {
            tableWrap.appendChild(el('div', { class: 'empty' }, '暂无数据，点击「新增案例」开始'));
            return;
          }
          const table = el('table', { class: 'table' });
          const thead = el('thead', {}, el('tr', {},
            el('th', { style: { width: '24%' } }, '标题'),
            el('th', {}, '描述'),
            el('th', { class: 'col-hide-sm', style: { width: '12%' } }, '日期'),
            el('th', { class: 'col-hide-sm', style: { width: '16%' } }, '标签'),
            el('th', { style: { width: '1%', whiteSpace: 'nowrap' } }, '操作'),
          ));
          const tbody = el('tbody');
          for (const c of state.cases) {
            const tagsCell = el('td', { class: 'col-hide-sm' },
              el('div', { style: { display: 'flex', flexWrap: 'wrap' } },
                ...(c.tags || []).map((t) => el('span', { class: 'tag' }, t))
              )
            );
            const editBtn = el('button', { class: 'btn btn-secondary btn-sm', onclick: () => openCaseForm(c) }, '编辑');
            const delBtn = el('button', { class: 'btn btn-danger btn-sm', onclick: () => deleteCase(c) }, '删除');
            const tr = el('tr', {},
              el('td', {}, el('div', { style: { fontWeight: 600 } }, c.title || '(无标题)')),
              el('td', {}, el('div', { style: { color: '#475569', maxWidth: '380px', overflow: 'hidden', textOverflow: 'ellipsis', display: '-webkit-box', WebkitLineClamp: 2, WebkitBoxOrient: 'vertical' } }, c.description || '')),
              el('td', { class: 'col-hide-sm' }, fmtDate(c.date)),
              tagsCell,
              el('td', {}, el('div', { class: 'table-actions' }, editBtn, delBtn)),
            );
            tbody.appendChild(tr);
          }
          table.append(thead, tbody);
          tableWrap.appendChild(table);
        };
        renderTable();

        wrap.append(head, tableWrap);
        if (state.cases.length === 0) loadCases().then(renderTable);
        return wrap;
      }

      async function loadCases() {
        try {
          const r = await apiContent.list('cases');
          state.cases = r.items || [];
          renderShell();
        } catch (e) { toast(`加载案例失败：${e.message}`, 'error'); }
      }

      async function openCaseForm(item) {
        const isEdit = !!item;
        const form = el('form', { style: { display: 'flex', flexDirection: 'column', gap: '12px' } });
        const today = new Date().toISOString().slice(0, 10);
        const f = {
          title: item?.title || '',
          description: item?.description || '',
          thumbnail: item?.thumbnail || '',
          tags: (item?.tags || []).join(', '),
          date: fmtDate(item?.date) || today,
        };
        // 编辑时拉一次原文，保留正文（不破坏 markdown body）
        let existingBody = '';
        if (isEdit) {
          try {
            const file = await apiContent.get(item.path);
            const stripped = file.content.replace(/^---\r?\n[\s\S]*?\r?\n---\r?\n?/, '');
            existingBody = stripped;
          } catch (e) { toast('加载原文失败：' + e.message, 'error'); return; }
        }
        const titleInp = el('input', { class: 'form-input', type: 'text', value: f.title, required: true });
        const descInp = el('textarea', { class: 'form-input', required: true }, f.description);
        const thumbInp = el('input', { class: 'form-input', type: 'text', value: f.thumbnail, placeholder: '/images/cases/xxx.png' });
        const tagsInp = el('input', { class: 'form-input', type: 'text', value: f.tags, placeholder: '逗号分隔，例如：网站建设, 响应式' });
        const dateInp = el('input', { class: 'form-input', type: 'date', value: f.date, required: true });
        const bodyInp = el('textarea', { class: 'form-input', style: { minHeight: '120px', fontFamily: 'ui-monospace, SFMono-Regular, Menlo, monospace', fontSize: '13px' } }, existingBody);
        const bodyFileInput = el('input', { type: 'file', accept: 'image/png,image/jpeg,image/jpg,image/gif,image/webp,image/svg+xml', style: { display: 'none' } });
        const bodyUploadBtn = el('button', { class: 'btn btn-secondary btn-sm', type: 'button', style: { marginTop: '6px' }, onclick: () => bodyFileInput.click() }, '📷 上传图片到正文');
        bodyFileInput.addEventListener('change', async () => {
          const file = bodyFileInput.files[0];
          if (!file) return;
          bodyUploadBtn.disabled = true; bodyUploadBtn.textContent = '上传中...';
          try {
            const r = await apiUpload(file);
            const md = `![${file.name}](${r.url})`;
            const start = bodyInp.selectionStart;
            bodyInp.value = bodyInp.value.slice(0, start) + md + bodyInp.value.slice(bodyInp.selectionEnd);
            bodyInp.selectionStart = bodyInp.selectionEnd = start + md.length;
            bodyInp.focus();
            toast('图片已插入', 'success');
          } catch (e) { toast('上传失败：' + e.message, 'error'); }
          finally { bodyUploadBtn.disabled = false; bodyUploadBtn.textContent = '📷 上传图片到正文'; bodyFileInput.value = ''; }
        });
        const bodyWrap = el('div', {}, bodyInp, bodyFileInput, bodyUploadBtn);

        form.append(
          mkField('标题', titleInp, true),
          mkField('描述', descInp, true),
          mkField('缩略图 URL（可空）', thumbInp),
          mkField('标签（逗号分隔）', tagsInp),
          mkField('日期', dateInp, true),
          mkField('正文内容（Markdown）', bodyWrap),
        );

        const submit = el('button', { class: 'btn btn-primary', type: 'submit' }, isEdit ? '保存' : '创建');
        const cancel = el('button', { class: 'btn btn-secondary', type: 'button', onclick: () => close() }, '取消');
        const onSubmit = async (e) => {
          e.preventDefault();
          const data = {
            title: titleInp.value.trim(),
            description: descInp.value.trim(),
            thumbnail: thumbInp.value.trim() || undefined,
            tags: tagsInp.value.split(',').map((t) => t.trim()).filter(Boolean),
            date: dateInp.value,
          };
          if (!data.title || !data.description || !data.date) { toast('请填写必填项', 'error'); return; }
          submit.disabled = true; submit.textContent = '保存中...';
          try {
            const payload = { type: 'cases', data, content: bodyInp.value };
            if (isEdit) {
              payload.path = item.path;
              payload.sha = item.sha;
            }
            const r = await apiContent.save(payload);
            toast('已保存，30-60 秒后线上生效', 'success');
            close();
            await loadCases();
            return r;
          } catch (err) {
            toast(`保存失败：${err.message}`, 'error');
            submit.disabled = false; submit.textContent = isEdit ? '保存' : '创建';
          }
        };
        form.addEventListener('submit', onSubmit);
        const foot = el('div', { style: { display: 'flex', gap: '8px' } }, cancel, submit);
        const close = showModal({ title: isEdit ? '编辑案例' : '新增案例', body: form, foot });
      }

      async function deleteCase(item) {
        if (!confirm(`确认删除「${item.title || item.filename}」？此操作会立即提交到 GitHub。`)) return;
        try {
          await apiContent.remove(item.path, item.sha);
          toast('已删除', 'success');
          await loadCases();
        } catch (e) { toast(`删除失败：${e.message}`, 'error'); }
      }

      // ===== 服务面板 =====
      function renderServicesPanel() {
        const wrap = el('div');
        const refreshBtn = el('button', { class: 'btn btn-secondary btn-sm', onclick: loadServices }, '↻ 刷新');
        const newBtn = el('button', { class: 'btn btn-primary btn-sm', onclick: () => openServiceForm() }, '+ 新增服务');

        const head = el('div', { class: 'panel-header' },
          el('div', {},
            el('div', { class: 'panel-title' }, '产品服务'),
            el('div', { class: 'panel-sub' }, `共 ${state.services.length} 条 · 拖动 order 调整排序`)
          ),
          el('div', { style: { display: 'flex', gap: '8px' } }, refreshBtn, newBtn)
        );

        const tableWrap = el('div', { class: 'card' });
        const renderTable = () => {
          tableWrap.innerHTML = '';
          if (state.services.length === 0) {
            tableWrap.appendChild(el('div', { class: 'empty' }, '暂无数据，点击「新增服务」开始'));
            return;
          }
          const table = el('table', { class: 'table' });
          const thead = el('thead', {}, el('tr', {},
            el('th', { style: { width: '5%' } }, '序'),
            el('th', { style: { width: '22%' } }, '标题'),
            el('th', {}, '描述'),
            el('th', { class: 'col-hide-sm', style: { width: '12%' } }, '图标'),
            el('th', { style: { width: '1%', whiteSpace: 'nowrap' } }, '操作'),
          ));
          const tbody = el('tbody');
          for (const s of state.services) {
            const tr = el('tr', {},
              el('td', {}, el('span', { class: 'tag' }, String(s.order ?? 0))),
              el('td', {}, el('div', { style: { fontWeight: 600 } }, s.title || '(无标题)')),
              el('td', {}, el('div', { style: { color: '#475569', maxWidth: '380px', overflow: 'hidden', textOverflow: 'ellipsis', display: '-webkit-box', WebkitLineClamp: 2, WebkitBoxOrient: 'vertical' } }, s.description || '')),
              el('td', { class: 'col-hide-sm' }, s.icon || '-'),
              el('td', {}, el('div', { class: 'table-actions' },
                el('button', { class: 'btn btn-secondary btn-sm', onclick: () => openServiceForm(s) }, '编辑'),
                el('button', { class: 'btn btn-danger btn-sm', onclick: () => deleteService(s) }, '删除'),
              )),
            );
            tbody.appendChild(tr);
          }
          table.append(thead, tbody);
          tableWrap.appendChild(table);
        };
        renderTable();

        wrap.append(head, tableWrap);
        if (state.services.length === 0) loadServices().then(renderTable);
        return wrap;
      }

      async function loadServices() {
        try {
          const r = await apiContent.list('services');
          state.services = (r.items || []).sort((a, b) => (a.order ?? 0) - (b.order ?? 0));
          renderShell();
        } catch (e) { toast(`加载服务失败：${e.message}`, 'error'); }
      }

      async function openServiceForm(item) {
        const isEdit = !!item;
        const form = el('form', { style: { display: 'flex', flexDirection: 'column', gap: '12px' } });
        const f = {
          title: item?.title || '',
          description: item?.description || '',
          icon: item?.icon || '',
          order: item?.order ?? 0,
        };
        let existingBody = '';
        if (isEdit) {
          try {
            const file = await apiContent.get(item.path);
            const stripped = file.content.replace(/^---\r?\n[\s\S]*?\r?\n---\r?\n?/, '');
            existingBody = stripped;
          } catch (e) { toast('加载原文失败：' + e.message, 'error'); return; }
        }
        const titleInp = el('input', { class: 'form-input', type: 'text', value: f.title, required: true });
        const descInp = el('textarea', { class: 'form-input', required: true }, f.description);
        const iconInp = el('input', { class: 'form-input', type: 'text', value: f.icon, placeholder: '如：globe、cart（可空）' });
        const orderInp = el('input', { class: 'form-input', type: 'number', value: f.order });
        const bodyInp = el('textarea', { class: 'form-input', style: { minHeight: '120px', fontFamily: 'ui-monospace, SFMono-Regular, Menlo, monospace', fontSize: '13px' } }, existingBody);
        const bodyFileInput2 = el('input', { type: 'file', accept: 'image/png,image/jpeg,image/jpg,image/gif,image/webp,image/svg+xml', style: { display: 'none' } });
        const bodyUploadBtn2 = el('button', { class: 'btn btn-secondary btn-sm', type: 'button', style: { marginTop: '6px' }, onclick: () => bodyFileInput2.click() }, '📷 上传图片到正文');
        bodyFileInput2.addEventListener('change', async () => {
          const file = bodyFileInput2.files[0];
          if (!file) return;
          bodyUploadBtn2.disabled = true; bodyUploadBtn2.textContent = '上传中...';
          try {
            const r = await apiUpload(file);
            const md = `![${file.name}](${r.url})`;
            const start = bodyInp.selectionStart;
            bodyInp.value = bodyInp.value.slice(0, start) + md + bodyInp.value.slice(bodyInp.selectionEnd);
            bodyInp.selectionStart = bodyInp.selectionEnd = start + md.length;
            bodyInp.focus();
            toast('图片已插入', 'success');
          } catch (e) { toast('上传失败：' + e.message, 'error'); }
          finally { bodyUploadBtn2.disabled = false; bodyUploadBtn2.textContent = '📷 上传图片到正文'; bodyFileInput2.value = ''; }
        });
        const bodyWrap2 = el('div', {}, bodyInp, bodyFileInput2, bodyUploadBtn2);

        form.append(
          mkField('标题', titleInp, true),
          mkField('描述', descInp, true),
          mkField('图标（可空）', iconInp),
          mkField('排序（数字越小越靠前）', orderInp),
          mkField('正文内容（Markdown）', bodyWrap2),
        );

        const submit = el('button', { class: 'btn btn-primary', type: 'submit' }, isEdit ? '保存' : '创建');
        const cancel = el('button', { class: 'btn btn-secondary', type: 'button', onclick: () => close() }, '取消');
        const onSubmit = async (e) => {
          e.preventDefault();
          const data = {
            title: titleInp.value.trim(),
            description: descInp.value.trim(),
            icon: iconInp.value.trim() || undefined,
            order: Number(orderInp.value || 0),
          };
          if (!data.title || !data.description) { toast('请填写必填项', 'error'); return; }
          submit.disabled = true; submit.textContent = '保存中...';
          try {
            const payload = { type: 'services', data, content: bodyInp.value };
            if (isEdit) { payload.path = item.path; payload.sha = item.sha; }
            await apiContent.save(payload);
            toast('已保存，30-60 秒后线上生效', 'success');
            close();
            await loadServices();
          } catch (err) {
            toast(`保存失败：${err.message}`, 'error');
            submit.disabled = false; submit.textContent = isEdit ? '保存' : '创建';
          }
        };
        form.addEventListener('submit', onSubmit);
        const foot = el('div', { style: { display: 'flex', gap: '8px' } }, cancel, submit);
        const close = showModal({ title: isEdit ? '编辑服务' : '新增服务', body: form, foot });
      }

      async function deleteService(item) {
        if (!confirm(`确认删除「${item.title || item.filename}」？`)) return;
        try {
          await apiContent.remove(item.path, item.sha);
          toast('已删除', 'success');
          await loadServices();
        } catch (e) { toast(`删除失败：${e.message}`, 'error'); }
      }

      // ===== 站点信息 =====
      function renderSitePanel() {
        const wrap = el('div');
        const head = el('div', { class: 'panel-header' },
          el('div', {},
            el('div', { class: 'panel-title' }, '站点信息'),
            el('div', { class: 'panel-sub' }, '对应 src/content/site.json · 修改后立即生效')
          )
        );

        const ta = el('textarea', { class: 'form-input', style: { minHeight: '420px' }, id: 'siteTa' }, state.site.raw || '');
        const loadBtn = el('button', { class: 'btn btn-secondary', onclick: loadSite }, '↻ 重新加载');
        const saveBtn = el('button', { class: 'btn btn-primary', onclick: saveSite }, '保存');
        const foot = el('div', { style: { display: 'flex', gap: '8px', justifyContent: 'flex-end', marginTop: '12px' } }, loadBtn, saveBtn);

        const card = el('div', { class: 'card', style: { padding: '20px' } },
          el('div', { class: 'helper' }, '直接编辑 JSON 文本，保存时会校验合法性。'),
          ta,
          el('div', { class: 'err-text', id: 'siteErr' }),
          foot
        );

        wrap.append(head, card);
        if (!state.site.raw) loadSite();
        return wrap;
      }

      async function loadSite() {
        try {
          const r = await apiSite.load();
          state.site.sha = r.sha;
          state.site.raw = JSON.stringify(r.data, null, 2);
          renderShell();
        } catch (e) { toast(`加载站点信息失败：${e.message}`, 'error'); }
      }

      async function saveSite() {
        const ta = $('#siteTa');
        const err = $('#siteErr');
        let data;
        try { data = JSON.parse(ta.value); }
        catch (e) { err.textContent = 'JSON 解析失败：' + e.message; return; }
        err.textContent = '';
        try {
          await apiSite.save(data, state.site.sha);
          toast('已保存，30-60 秒后线上生效', 'success');
          await loadSite();
        } catch (e) { toast(`保存失败：${e.message}`, 'error'); }
      }

      // ===== 图片上传 =====
      function renderUploadPanel() {
        const wrap = el('div');
        const head = el('div', { class: 'panel-header' },
          el('div', {},
            el('div', { class: 'panel-title' }, '图片上传'),
            el('div', { class: 'panel-sub' }, '支持 png / jpg / jpeg / gif / webp / svg，上传后可在 case / service 表单里引用 URL')
          )
        );

        const fileInput = el('input', { type: 'file', accept: 'image/png,image/jpeg,image/jpg,image/gif,image/webp,image/svg+xml' });
        const uploadBtn = el('button', { class: 'btn btn-primary', onclick: doUpload }, '上传');
        const errBox = el('div', { class: 'err-text' });
        const zone = el('div', { class: 'upload-zone' },
          el('div', { style: { marginBottom: '12px', color: '#475569' } }, '📁 选择本地图片后点击「上传」'),
          el('div', { style: { display: 'flex', justifyContent: 'center', gap: '10px', alignItems: 'center', flexWrap: 'wrap' } }, fileInput, uploadBtn),
          errBox
        );
        // 拖拽高亮
        ['dragenter', 'dragover'].forEach((ev) => zone.addEventListener(ev, (e) => { e.preventDefault(); zone.classList.add('drag'); }));
        ['dragleave', 'drop'].forEach((ev) => zone.addEventListener(ev, (e) => { e.preventDefault(); zone.classList.remove('drag'); }));
        zone.addEventListener('drop', (e) => { if (e.dataTransfer.files[0]) { fileInput.files = e.dataTransfer.files; } });

        const list = el('div', { class: 'upload-list' });
        const renderList = () => {
          list.innerHTML = '';
          if (state.uploads.length === 0) {
            list.appendChild(el('div', { class: 'empty', style: { gridColumn: '1 / -1' } }, '本次会话上传记录'));
            return;
          }
          for (const u of state.uploads) {
            const urlInput = el('input', { type: 'text', value: u.url, readonly: true });
            const copyBtn = el('button', { class: 'btn btn-secondary btn-sm', onclick: () => copyToClipboard(u.url) }, '复制');
            list.appendChild(el('div', { class: 'upload-item' },
              el('div', { style: { fontSize: '12px', color: '#475569', marginBottom: '6px' } }, u.name),
              el('div', { class: 'url-row' }, urlInput, copyBtn)
            ));
          }
        };
        renderList();

        async function doUpload() {
          errBox.textContent = '';
          const f = fileInput.files[0];
          if (!f) { errBox.textContent = '请先选择文件'; return; }
          if (f.size > 10 * 1024 * 1024) { errBox.textContent = '文件超过 10MB，拒绝上传'; return; }
          uploadBtn.disabled = true; uploadBtn.textContent = '上传中...';
          try {
            const r = await apiUpload(f);
            toast('上传成功', 'success');
            state.uploads.unshift({ name: f.name, url: r.url, path: r.path });
            fileInput.value = '';
            renderList();
          } catch (e) { errBox.textContent = '上传失败：' + e.message; }
          finally { uploadBtn.disabled = false; uploadBtn.textContent = '上传'; }
        }

        wrap.append(head, zone, list);
        return wrap;
      }

      function copyToClipboard(text) {
        if (navigator.clipboard) {
          navigator.clipboard.writeText(text).then(() => toast('已复制到剪贴板', 'success'));
        } else {
          const ta = document.createElement('textarea');
          ta.value = text; document.body.appendChild(ta); ta.select();
          try { document.execCommand('copy'); toast('已复制', 'success'); } catch { toast('复制失败，请手动复制', 'error'); }
          document.body.removeChild(ta);
        }
      }

      function mkField(label, input, required = false) {
        return el('div', { class: 'form-group' },
          el('label', {}, label, required ? el('span', { class: 'req' }, ' *') : null),
          input
        );
      }

      function render() {
        if (state.token) renderShell();
        else renderLogin();
      }

      render();
    </script>
  </body>
</html>
