---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import site from '../content/site.json';

const cases = (await getCollection('cases')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);

const serviceIcons: Record<string, string> = {
  '网站建设': '🌐', '小程序开发': '📱', '公众号开发': '💬',
  'APP开发': '📲', '网络推广': '📈', '电商服务': '🛒',
  '直播服务': '📡', '微信抽奖': '🎁', '400电话': '📞',
  '商标注册': '™️', 'OA系统定制': '⚙️', '商城网站': '🏪',
  '网站空间': '☁️', '域名注册': '🔗', '企业邮箱': '📧',
  '企业画册': '📖', 'Logo设计': '🎨', '视频制作': '🎬',
  '运维服务': '🔧',
};
---

<Base title="首页" activeNav="home">
  <!-- Hero -->
  <section class="relative overflow-hidden pt-[calc(72px+80px)] pb-20 bg-gradient-to-br from-blue-50 via-sky-50 to-primary-light">
    <div class="hero-blob"></div>
    <div class="max-w-7xl mx-auto px-6 relative z-10">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-primary/10 rounded-full text-sm text-primary font-medium mb-6">
        云南红河 · 7年专注互联网技术服务
      </div>
      <h1 class="text-4xl md:text-5xl lg:text-[3.2rem] font-bold leading-tight mb-5">
        互联网+选<span class="text-primary">滇码科技</span>
      </h1>
      <p class="text-lg text-slate-500 max-w-xl mb-9">{site.description}</p>
      <div class="flex flex-wrap gap-3">
        <a href="/contact/" class="btn btn-primary">免费咨询 →</a>
        <a href="/cases/" class="btn btn-outline">查看案例</a>
      </div>
      <div class="flex gap-12 mt-12 pt-8 border-t border-primary/15">
        <div>
          <div class="text-3xl font-bold text-primary">{site.stats.years}</div>
          <div class="text-sm text-slate-400 mt-1">本土持久服务</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">{site.stats.clients}</div>
          <div class="text-sm text-slate-400 mt-1">企业建站客户</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-primary">{site.stats.longterm}</div>
          <div class="text-sm text-slate-400 mt-1">长期托管服务</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <div class="section-overline">产品服务</div>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">一站式互联网技术服务</h2>
        <p class="text-slate-500 max-w-xl mx-auto">结合创意、设计、营销、研发等多维度，为您提供更精准的方案</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.slice(0, 8).map((s) => (
          <div class="card">
            <div class="p-6">
              <div class="service-icon">{serviceIcons[s.data.title] || '⚡'}</div>
              <h3 class="font-semibold text-base mb-2">{s.data.title}</h3>
              <p class="text-sm text-slate-500 leading-relaxed">{s.data.description}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/services/" class="btn btn-outline">查看全部服务 →</a>
      </div>
    </div>
  </section>

  <!-- Cases -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-12">
        <div class="section-overline">客户案例</div>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">用案例说话</h2>
        <p class="text-slate-500 max-w-xl mx-auto">专注网页设计、小程序开发、APP开发，助力企业拥抱互联网+</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {cases.map((c) => (
          <a href={`/cases/${c.id}/`} class="card no-underline">
            <div class="p-6">
              <h3 class="font-semibold text-base mb-2 text-slate-900">{c.data.title}</h3>
              <p class="text-sm text-slate-500 leading-relaxed">{c.data.description}</p>
              <div class="mt-3 flex gap-2">
                {c.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/cases/" class="btn btn-outline">查看更多案例 →</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-r from-primary to-primary-dark text-white text-center">
    <div class="max-w-7xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-4 text-white">准备好开始了吗？</h2>
      <p class="text-lg opacity-85 mb-8 max-w-md mx-auto">一个微信、一个电话，开启一个项目的合作</p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/contact/" class="btn btn-white">联系我们</a>
        <a href={`tel:${site.phone_mobile}`} class="btn btn-ghost">拨打电话</a>
      </div>
    </div>
  </section>
</Base>
