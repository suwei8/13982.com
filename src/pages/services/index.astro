---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);

const serviceIcons: Record<string, string> = {
  '网站建设': '🌐', '小程序开发': '📱', '公众号开发': '💬',
  'APP开发': '📲', '网络推广': '📈', '电商服务': '🛒',
  '直播服务': '📡', '微信抽奖': '🎁', '400电话': '📞',
  '商标注册': '™️', 'OA系统定制': '⚙️', '商城网站': '🏪',
  '网站空间': '☁️', '域名注册': '🔗', '企业邮箱': '📧',
  '企业画册': '📖', 'Logo设计': '🎨', '视频制作': '🎬',
  '运维服务': '🔧',
};
---

<Base title="产品服务" activeNav="services">
  <section class="page-header">
    <div class="container">
      <h1>产品服务</h1>
      <p>一站式互联网技术服务，为您的企业赋能</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {services.map((s) => (
          <div class="card">
            <div class="card-body">
              <div class="service-icon">{serviceIcons[s.data.title] || '⚡'}</div>
              <h3>{s.data.title}</h3>
              <p>{s.data.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>
