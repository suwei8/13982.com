# MySQL connection for scripts/export-mysql.py
MYSQL_HOST=127.0.0.1
MYSQL_USER=admin
MYSQL_PASS=your_password_here
MYSQL_DB=com_13982

# EdgeOne Pages Functions - Gitee integration
# Must be configured in EdgeOne Pages environment variables; otherwise the
# admin UI can log in but content management API calls will fail.
GITEE_TOKEN=your_gitee_access_token_here
GITEE_OWNER=suwei8
GITEE_REPO=13982.com
GITEE_BRANCH=master
# Optional: override for private Gitee-compatible deployments
GITEE_API_BASE=https://gitee.com/api/v5

# Upload configuration
# UPLOAD_STORAGE can be 'gitee' or 'blob'. Use 'blob' to store uploads in EdgeOne Blob.
UPLOAD_STORAGE=gitee
UPLOAD_DIR=public/images/uploads
UPLOAD_URL_PREFIX=/images/uploads
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_EXTS=png,jpg,jpeg,gif,webp,svg

# EdgeOne Blob configuration, used when UPLOAD_STORAGE=blob
BLOB_STORE=uploads
BLOB_PREFIX=uploads
BLOB_READ_CONSISTENCY=strong

# Admin authentication
# ADMIN_PASS_HASH must be HMAC-SHA256(password, SESSION_SECRET). Generate with:
# node -e "const { createHmac } = require('crypto'); console.log(createHmac('sha256', process.env.SESSION_SECRET).update(process.env.ADMIN_PASS).digest('hex'))"
ADMIN_USER=admin
ADMIN_PASS_HASH=your_hmac_sha256_hex_of_password
# Optional: move admin UI away from /admin. Example: /dm-console-2026
ADMIN_PATH=/admin
SESSION_SECRET=your_session_signing_secret
