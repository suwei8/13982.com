---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map((c) => ({
    params: { slug: c.id },
    props: { caseData: c },
  }));
}

const { caseData } = Astro.props;
const { Content } = await render(caseData);
---

<Base title={caseData.data.title} description={caseData.data.description}>
  <section class="pt-[calc(72px+40px)] pb-20">
    <div class="max-w-3xl mx-auto px-6">
      <a href="/cases/" class="text-sm text-slate-500 hover:text-primary inline-flex items-center gap-1 mb-6 transition-colors">← 返回案例列表</a>
      <h1 class="text-3xl font-bold mb-3">{caseData.data.title}</h1>
      <p class="text-slate-500 mb-4">{caseData.data.description}</p>
      <div class="mb-8 flex gap-2 flex-wrap items-center">
        {caseData.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        <span class="text-xs text-slate-400 ml-1">
          {caseData.data.date.toLocaleDateString('zh-CN')}
        </span>
      </div>
      <article class="prose">
        <Content />
      </article>
    </div>
  </section>
</Base>
