---
import site from '../content/site.json';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}

const { title, description = site.description, activeNav = '' } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | {site.name}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans text-slate-900 leading-relaxed bg-white">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 h-[72px] bg-white/90 backdrop-blur-xl border-b border-slate-200 transition-shadow duration-300" id="nav">
      <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-full">
        <a class="text-xl font-bold text-slate-900 flex items-center gap-2 no-underline hover:text-slate-900" href="/">
          <span class="w-2 h-2 bg-primary rounded-full"></span>
          {site.name}
        </a>
        <button class="nav-toggle" id="navToggle" aria-label="菜单">
          <span></span><span></span><span></span>
        </button>
        <ul class="hidden md:flex items-center gap-1 list-none" id="navLinks">
          <li><a href="/" class={`nav-link ${activeNav === 'home' ? 'active' : ''}`}>首页</a></li>
          <li><a href="/about/" class={`nav-link ${activeNav === 'about' ? 'active' : ''}`}>关于我们</a></li>
          <li><a href="/services/" class={`nav-link ${activeNav === 'services' ? 'active' : ''}`}>产品服务</a></li>
          <li><a href="/cases/" class={`nav-link ${activeNav === 'cases' ? 'active' : ''}`}>客户案例</a></li>
          <li><a href="/contact/" class={`nav-link ${activeNav === 'contact' ? 'active' : ''}`}>联系我们</a></li>
          <li><a href="/contact/" class="btn btn-primary !py-2 !px-5 text-sm">免费咨询</a></li>
        </ul>
      </div>
    </nav>

    <slot />

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-400 pt-16 pb-8">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-10">
          <div>
            <div class="text-white text-lg font-bold mb-3">{site.name}</div>
            <p class="text-sm leading-relaxed">{site.description}</p>
            <p class="mt-4 text-xs">{site.address_full}</p>
          </div>
          <div>
            <h4 class="text-white text-sm font-semibold mb-4">产品服务</h4>
            <ul class="space-y-2 list-none p-0">
              <li><a href="/services/" class="text-sm text-slate-400 hover:text-white transition-colors">网站建设</a></li>
              <li><a href="/services/" class="text-sm text-slate-400 hover:text-white transition-colors">小程序开发</a></li>
              <li><a href="/services/" class="text-sm text-slate-400 hover:text-white transition-colors">APP开发</a></li>
              <li><a href="/services/" class="text-sm text-slate-400 hover:text-white transition-colors">网络推广</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white text-sm font-semibold mb-4">快速链接</h4>
            <ul class="space-y-2 list-none p-0">
              <li><a href="/about/" class="text-sm text-slate-400 hover:text-white transition-colors">关于我们</a></li>
              <li><a href="/cases/" class="text-sm text-slate-400 hover:text-white transition-colors">客户案例</a></li>
              <li><a href="/contact/" class="text-sm text-slate-400 hover:text-white transition-colors">联系我们</a></li>
            </ul>
          </div>
          <div>
            <h4 class="text-white text-sm font-semibold mb-4">联系方式</h4>
            <ul class="space-y-2 list-none p-0">
              <li class="text-sm">{site.phone_400}</li>
              <li class="text-sm">微信: {site.wechat}</li>
              <li><a href={`mailto:${site.email}`} class="text-sm text-slate-400 hover:text-white transition-colors">{site.email}</a></li>
            </ul>
          </div>
        </div>
        <div class="border-t border-slate-800 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs">
          <span>&copy; {new Date().getFullYear()} {site.company}</span>
          <a href="https://beian.miit.gov.cn/" target="_blank" rel="nofollow" class="text-slate-500 hover:text-slate-300 transition-colors">{site.icp}</a>
        </div>
      </div>
    </footer>

    <script>
      const nav = document.getElementById('nav');
      window.addEventListener('scroll', () => {
        nav?.classList.toggle('shadow-md', window.scrollY > 10);
      });
      document.getElementById('navToggle')?.addEventListener('click', () => {
        document.getElementById('navLinks')?.classList.toggle('hidden');
        document.getElementById('navLinks')?.classList.toggle('flex');
        document.getElementById('navLinks')?.classList.toggle('flex-col');
        document.getElementById('navLinks')?.classList.toggle('absolute');
        document.getElementById('navLinks')?.classList.toggle('top-[72px]');
        document.getElementById('navLinks')?.classList.toggle('left-0');
        document.getElementById('navLinks')?.classList.toggle('right-0');
        document.getElementById('navLinks')?.classList.toggle('bg-white');
        document.getElementById('navLinks')?.classList.toggle('p-6');
        document.getElementById('navLinks')?.classList.toggle('border-b');
        document.getElementById('navLinks')?.classList.toggle('border-slate-200');
        document.getElementById('navLinks')?.classList.toggle('shadow-lg');
      });
    </script>
  </body>
</html>
